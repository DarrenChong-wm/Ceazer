<hibernate-configuration>
    <session-factory>

        <!-- Database Connection Properties -->
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:5432/ceazerdb</property>
        <property name="hibernate.connection.username">ghua5155</property>
        <property name="hibernate.connection.password">ghua5155</property>

        <!-- Hibernate Dialect for PostgreSQL -->
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>

        <!-- Hibernate Properties -->
        <property name="hibernate.show_sql">true</property>   <!-- Show SQL in console -->
        <property name="hibernate.format_sql">true</property> <!-- Pretty print SQL -->
        <property name="hibernate.hbm2ddl.auto">update</property> <!-- Auto-generate tables -->

        <!-- Entity Class Mapping (Not required if using annotations) -->
        <!-- <mapping class="com.example.model.User"/> -->

    </session-factory>
</hibernate-configuration>